# ==============================================================================
# BOOKING TITANIUM - DOCKER COMPOSE DEV ENVIRONMENT (EXAMPLE)
# ==============================================================================
# Copy this file to .env and update with your values:
#   cp .env.example .env
#
# IMPORTANT: This file contains ONLY Docker configuration.
# All production credentials are in ~/.bashrc (not committed to git).
# ==============================================================================

# ==============================================================================
# DATABASE - Docker PostgreSQL (Local Development Only)
# ==============================================================================
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=your_local_db_password
POSTGRES_DB=n8n_db_titanium
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data/pgdata

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_PORT=6379
REDIS_PASSWORD=your_local_redis_password

# ==============================================================================
# API SERVER
# ==============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=debug
LOG_FORMAT=json

# ==============================================================================
# PRODUCTION CREDENTIALS (NOT HERE!)
# ==============================================================================
# The following credentials are NOT in this file.
# They are configured in ~/.bashrc for security:
#
# - NEON_DATABASE_URL (PostgreSQL Neon production)
# - DEV_LOCAL_GCAL_KEY_PATH (Google Calendar credentials)
# - DEV_LOCAL_GMAIL_USER (Gmail SMTP username)
# - DEV_LOCAL_GMAIL_PASS (Gmail SMTP password)
# - DEV_LOCAL_TELEGRAM_TOKEN (Telegram bot token)
# - GROQ_API_KEY (Groq LLM API key)
# - OPENAI_API_KEY (OpenAI API key)
#
# See docs/ENV_CLEANUP_REPORT.md for details.
# ==============================================================================
