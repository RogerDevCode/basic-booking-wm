{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/manager/Sync/wildmill-proyects/booking-titanium-wm"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "gemini-docs": {
      "url": "https://developerknowledge.googleapis.com/mcp",
      "type": "sse",
      "headers": {
        "X-Goog-Api-Key": "$GOOGLE_API_KEY"
      }
    },
    "token-savior": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "token_savior.server"
      ],
      "env": {
        "WORKSPACE_ROOTS": "/home/manager/Sync/wildmill-proyects/booking-titanium-wm",
        "TOKEN_SAVIOR_PROFILE": "tiny_plus",
        "TS_AUTO_EXTRACT": "1",
        "TS_VIEWER_PORT": "3000"
      }
    }
  }
}
