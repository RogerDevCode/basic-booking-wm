# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

REDIS_ADDR=redis:6379
REDIS_PASSWORD=change_this_to_secure_password_min_32_chars

# ============================================================================
# LLM PROVIDERS (Fallback Order: Groq → OpenAI → Anthropic)
# ============================================================================

# Primary provider (Priority 1)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Secondary provider (Priority 2)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Tertiary provider (Priority 3)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ============================================================================
# MONITORING & ALERTS
# ============================================================================

ENABLE_ALERTS=true

# Slack webhook for critical alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Grafana admin password (for dashboard access)
GRAFANA_PASSWORD=change_this_to_secure_password

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Cache TTL in seconds (1 hour default)
CACHE_TTL=3600

# Semantic similarity threshold (0.95 = 95% similar)
SIMILARITY_THRESHOLD=0.95

# Maximum cache entries (LRU eviction)
MAX_CACHE_SIZE=10000

# ============================================================================
# TIMEOUTS & RETRIES
# ============================================================================

# Request timeout
REQUEST_TIMEOUT=30s

# Cache timeout (fast fail)
CACHE_TIMEOUT=5s

# Circuit breaker settings
CIRCUIT_BREAKER_MAX_FAILURES=5
CIRCUIT_BREAKER_TIMEOUT=60s
CIRCUIT_BREAKER_HALF_OPEN_REQS=3

# Retry settings
MAX_RETRIES=3
RETRY_BACKOFF_BASE=1s
RETRY_BACKOFF_MULTIPLIER=3

# ============================================================================
# RATE LIMITING
# ============================================================================

# Per-user rate limit (requests per minute)
USER_RATE_LIMIT=100

# Per-IP rate limit (requests per minute)
IP_RATE_LIMIT=1000

# Global rate limit (requests per minute)
GLOBAL_RATE_LIMIT=10000

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Canary deployment percentage (5% for initial rollout)
CANARY_PERCENTAGE=5

# Canary monitoring duration in seconds (1 hour)
CANARY_DURATION=3600

# Health check settings
HEALTH_CHECK_RETRIES=3
HEALTH_CHECK_INTERVAL=10

# ============================================================================
# LOGGING
# ============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log format (json, text)
LOG_FORMAT=json

# ============================================================================
# SECURITY
# ============================================================================

# Enable input validation
ENABLE_INPUT_VALIDATION=true

# Max input text length (characters)
MAX_INPUT_LENGTH=500

# Enable output validation
ENABLE_OUTPUT_VALIDATION=true

# Enable content moderation
ENABLE_CONTENT_MODERATION=true

# ============================================================================
# COST TRACKING
# ============================================================================

# Cost alerts threshold (USD per request)
MAX_COST_PER_REQUEST=0.01

# Daily budget alert threshold (USD)
DAILY_BUDGET_ALERT=50.00

# ============================================================================
# PERFORMANCE TARGETS
# ============================================================================

# Target latency P50 (milliseconds)
TARGET_LATENCY_P50=200

# Target latency P95 (milliseconds)
TARGET_LATENCY_P95=1000

# Target cache hit rate (0.20 = 20%)
TARGET_CACHE_HIT_RATE=0.20

# Target error rate (0.05 = 5%)
TARGET_ERROR_RATE=0.05
