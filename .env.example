# ============================================================================
# .env.example — Referencia de variables de entorno requeridas
# ============================================================================
# Copia este archivo como .env y completa con tus credenciales.
# Los archivos .env* (excepto .env.example) están en .gitignore.
# ============================================================================

# === DATABASE (Required — Neon PostgreSQL, Supabase, or self-hosted) ===
DATABASE_URL=postgresql://user:password@host:5432/database_name?sslmode=require

# === GOOGLE CALENDAR (Required for GCal sync) ===
# Access token (short-lived — implement refresh mechanism)
GCAL_ACCESS_TOKEN=ya29.xxx
# OAuth credentials for token refresh
GCAL_CLIENT_ID=xxx.apps.googleusercontent.com
GCAL_CLIENT_SECRET=GOCSPX-xxx
GCAL_REFRESH_TOKEN=1//xxx
# Calendar IDs (one per provider in production)
GCAL_PROVIDER_CALENDAR_ID=provider@group.calendar.google.com
GCAL_PATIENT_CALENDAR_ID=patient@gmail.com

# === TELEGRAM (Required for Telegram bot) ===
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDEFxxxxx
# Optional: webhook secret for verification
TELEGRAM_WEBHOOK_SECRET=your_secret_here

# === GMAIL / SMTP (Required for email notifications) ===
# Use App Password, NOT account password
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_password_here
# Optional: override SMTP settings (defaults to Gmail SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# GMAIL_FROM_NAME=Sistema de Citas Medicas

# === AI / LLM (Required for intent classification) ===
# ─── Provider Chain (Configurable order, defaults to: groq → groq2 → openai) ───
# Supported tokens: groq, groq2, openai
# Examples:
#   "groq"              → Only Groq (fastest, cheapest)
#   "groq,openai"       → Groq first, OpenAI fallback
#   "openai,groq"                    → OpenAI first, Groq fallback
#   "openai,groq,groq2,openrouter"   → Full chain with free fallback (default v6)
LLM_PROVIDER_ORDER=openai,groq,groq2,openrouter

# ─── Groq (Primary provider) ───
# Get free API key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=openai/gpt-oss-20b
# ─── Groq Secondary (fallback when primary key is exhausted/rate-limited) ───
GROQ_API_KEY_2=gsk_yyy
GROQ_MODEL_2=llama-3.3-70b-versatile
# ─── OpenAI (Fallback) ───
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
# ─── OpenRouter (Free fallback — auto-routes between free models) ───
# Get free API key at https://openrouter.ai/keys (no credit card required)
OPENROUTER_API_KEY=sk-or-v1_xxx
OPENROUTER_MODEL=openrouter/auto:free

# ─── Timeout (ms) for LLM requests ───
# Default: 15000 (15 seconds)
# GROQ_LLM_TIMEOUT_MS=15000

# === WINDMILL (Optional, auto-detected when running in Windmill) ===
# Only needed for local development outside Windmill
WINDMILL_BASE_URL=https://app.windmill.dev
# Public URL for GCal webhooks (must be accessible by Google)
WINDMILL_WEBHOOK_BASE_URL=https://app.windmill.dev/api/w/your-workspace/webhooks
# Windmill image version (Ensure Python 3.13 is used)
WM_IMAGE=ghcr.io/windmill-labs/windmill:latest-python313

# === REDIS (Optional, for caching and distributed locks) ===
# REDIS_URL=redis://localhost:6379

# === APPLICATION (Optional, have sensible defaults) ===
# NODE_ENV=production
# LOG_LEVEL=info
