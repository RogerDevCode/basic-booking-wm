{
  "$schema": "https://json.schemastore.org/eslintrc",
  "_comment": "Booking Titanium - ESLint Strict TypeScript Configuration",
  "_version": "1.0.0",
  "_description": "Enforces all rules from @docs/STRICT_RULES.md",

  "root": true,

  "env": {
    "es2022": true,
    "node": true
  },

  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": ["./tsconfig.strict.json"]
  },

  "plugins": [
    "@typescript-eslint",
    "typescript-enum",
    "no-null",
    "sonarjs",
    "unicorn"
  ],

  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:@typescript-eslint/strict",
    "plugin:@typescript-eslint/stylistic",
    "plugin:sonarjs/recommended",
    "plugin:unicorn/recommended"
  ],

  "rules": {
    // ========================================================================
    // REGLA 0.1: PROHIBIDO any (enforced by @typescript-eslint/no-explicit-any)
    // ========================================================================
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unsafe-assignment": "error",
    "@typescript-eslint/no-unsafe-member-access": "error",
    "@typescript-eslint/no-unsafe-call": "error",
    "@typescript-eslint/no-unsafe-return": "error",

    // ========================================================================
    // REGLA 0.2: PROHIBIDO undefined implícito
    // ========================================================================
    "no-null/no-null": "off",  // Permitimos null explícito
    "@typescript-eslint/no-undefined": "off",  // undefined es válido en JS
    "@typescript-eslint/no-invalid-void-type": "error",

    // ========================================================================
    // REGLA 0.3: PROHIBIDO NaN sin validación
    // ========================================================================
    "no-constant-condition": "error",
    "no-self-compare": "error",
    "@typescript-eslint/no-redundant-type-constituents": "error",

    // ========================================================================
    // REGLA 0.4: PROHIBIDO unknown sin type guard
    // ========================================================================
    "@typescript-eslint/no-unknown-property": "error",
    "@typescript-eslint/no-inferrable-types": "error",

    // ========================================================================
    // REGLA 0.5: PROHIBIDO index access sin check
    // ========================================================================
    "@typescript-eslint/no-array-delete": "error",
    "@typescript-eslint/prefer-for-of": "error",

    // ========================================================================
    // REGLA 0.6: PROHIBIDO coerciones implícitas
    // ========================================================================
    "no-implicit-coercion": ["error", {
      "boolean": true,
      "number": true,
      "string": true
    }],
    "@typescript-eslint/no-base-to-string": "error",
    "@typescript-eslint/restrict-template-expressions": "error",

    // ========================================================================
    // REGLA 0.7: OBLIGATORIO return type explícito
    // ========================================================================
    "@typescript-eslint/explicit-function-return-type": ["error", {
      "allowExpressions": false,
      "allowTypedFunctionExpressions": true,
      "allowHigherOrderFunctions": true,
      "allowDirectConstAssertionInArrowFunctions": true,
      "allowConciseArrowFunctionExpressionsStartingWithVoid": false
    }],
    "@typescript-eslint/explicit-module-boundary-types": "error",

    // ========================================================================
    // REGLA 0.8: OBLIGATORIO catch con type guard
    // ========================================================================
    "@typescript-eslint/no-implicit-any-catch": "error",
    "@typescript-eslint/prefer-promise-reject-errors": "error",

    // ========================================================================
    // REGLA 0.9: OBLIGATORIO switch exhaustivo
    // ========================================================================
    "@typescript-eslint/switch-exhaustiveness-check": "error",
    "default-case-last": "error",

    // ========================================================================
    // REGLA 0.10: OBLIGATORIO optional explícito
    // ========================================================================
    "@typescript-eslint/no-unnecessary-type-arguments": "error",
    "@typescript-eslint/prefer-nullish-coalescing": "error",
    "@typescript-eslint/prefer-optional-chain": "error",

    // ========================================================================
    // REGLA 1.1-1.2: OBLIGATORIO Result/Option patterns
    // ========================================================================
    // No se puede enforcear automáticamente, pero podemos desalentar throw
    "no-throw-literal": "error",
    "@typescript-eslint/only-throw-error": "error",
    "prefer-promise-reject-errors": "error",

    // ========================================================================
    // REGLA 1.3: OBLIGATORIO branding
    // ========================================================================
    // No se puede enforcear automáticamente

    // ========================================================================
    // REGLA 1.4: OBLIGATORIO type guards
    // ========================================================================
    "@typescript-eslint/no-type-alias": "off",  // Permitimos type aliases
    "@typescript-eslint/prefer-includes": "error",

    // ========================================================================
    // REGLA 1.5: OBLIGATORIO as const
    // ========================================================================
    "@typescript-eslint/prefer-as-const": "error",
    "@typescript-eslint/prefer-literal-enum-member": "error",

    // ========================================================================
    // REGLA 1.6: OBLIGATORIO satisfies
    // ========================================================================
    // No se puede enforcear automáticamente (TypeScript 5.0+)

    // ========================================================================
    // REGLA 1.7: OBLIGATORIO readonly
    // ========================================================================
    "@typescript-eslint/prefer-readonly": "error",
    "@typescript-eslint/prefer-readonly-parameter-types": "warn",
    "prefer-const": ["error", {
      "destructuring": "all",
      "ignoreReadBeforeAssign": false
    }],

    // ========================================================================
    // REGLA 1.8: OBLIGATORIO discriminated unions
    // ========================================================================
    // No se puede enforcear automáticamente

    // ========================================================================
    // REGLA 1.9: OBLIGATORIO tipos explícitos
    // ========================================================================
    "@typescript-eslint/no-var-requires": "error",
    "no-var": "error",
    "prefer-const": "error",

    // ========================================================================
    // REGLA 1.10: OBLIGATORIO noUncheckedIndexedAccess
    // ========================================================================
    // Se configura en tsconfig.strict.json

    // ========================================================================
    // SONARJS - Calidad adicional
    // ========================================================================
    "sonarjs/no-all-duplicated-branches": "error",
    "sonarjs/no-collapsible-if": "error",
    "sonarjs/no-collection-size-mischeck": "error",
    "sonarjs/no-duplicate-string": "warn",
    "sonarjs/no-duplicated-branches": "error",
    "sonarjs/no-element-overwrite": "error",
    "sonarjs/no-empty-collection": "error",
    "sonarjs/no-extra-arguments": "error",
    "sonarjs/no-identical-conditions": "error",
    "sonarjs/no-identical-expressions": "error",
    "sonarjs/no-ignored-return": "error",
    "sonarjs/no-one-iteration-loop": "error",
    "sonarjs/no-use-of-empty-return-value": "error",
    "sonarjs/non-existent-operator": "error",

    // ========================================================================
    // UNICORN - Modern best practices
    // ========================================================================
    "unicorn/catch-error-name": ["error", {
      "name": "error"
    }],
    "unicorn/prefer-array-find": "error",
    "unicorn/prefer-array-flat": "error",
    "unicorn/prefer-array-some": "error",
    "unicorn/prefer-at": "error",
    "unicorn/prefer-includes": "error",
    "unicorn/prefer-negative-index": "error",
    "unicorn/prefer-number-properties": "error",
    "unicorn/prefer-optional-catch-binding": "error",
    "unicorn/prefer-set-has": "error",
    "unicorn/prefer-string-slice": "error",
    "unicorn/prefer-string-starts-ends-with": "error",
    "unicorn/prefer-string-trim-start-end": "error",
    "unicorn/prefer-type-error": "error"
  },

  "overrides": [
    {
      "files": ["*.test.ts", "*.spec.ts"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off",
        "@typescript-eslint/no-non-null-assertion": "off",
        "unicorn/prefer-module": "off"
      }
    },
    {
      "files": ["f/**/*.ts"],
      "rules": {
        "unicorn/prefer-module": "off",
        "@typescript-eslint/no-unused-vars": "off"
      }
    }
  ],

  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "coverage/",
    "*.js",
    "*.d.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/backup/*.ts",
    "**/v2.0_backup.ts",
    "**/v2.1_backup.ts",
    "**/v2.2_backup.ts"
  ]
}
