{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "Booking Titanium - TypeScript Strict Configuration (Go-like)",
  "_version": "1.0.0",
  "_description": "Production-grade TypeScript config with Go-level type safety",

  "extends": "@tsconfig/strictest/tsconfig.json",

  "compilerOptions": {
    // ============================================================================
    // STRICT TYPE CHECKING (NO NEGOCIABLE - Go-level safety)
    // ============================================================================
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,

    // ============================================================================
    // PROHIBICIONES EXPLÍCITAS (Equivalente a Go's type safety)
    // ============================================================================
    
    // ❌ NUNCA permitir 'any' implícito
    "noImplicitAny": true,
    
    // ❌ null/undefined deben ser explícitos (como Go's var x *Type = nil)
    "strictNullChecks": true,
    
    // ❌ Todas las rutas de función deben retornar (como Go's compile error)
    "noImplicitReturns": true,
    
    // ❌ No fallthrough en switch (como Go's explicit fallthrough)
    "noFallthroughCasesInSwitch": true,
    
    // ❌ 'this' debe tener tipo explícito
    "noImplicitThis": true,
    
    // ❌ Variables no usadas = error (como Go's unused variable error)
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    
    // ✅ Array/Object index access puede ser undefined (como Go's ok pattern)
    "noUncheckedIndexedAccess": true,
    
    // ✅ Optional properties no pueden ser undefined (como Go's explicit nil)
    "exactOptionalPropertyTypes": true,
    
    // ✅ Consistencia en acceso a propiedades
    "noPropertyAccessFromIndexSignature": true,
    
    // ✅ override keyword requerida (como Go's explicit method override)
    "noImplicitOverride": true,
    
    // ✅ Errores en catch son 'unknown' (type-safe error handling)
    "useUnknownInCatchVariables": true,

    // ============================================================================
    // MÓDULOS (Windmill + Bun compatible)
    // ============================================================================
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,

    // ============================================================================
    // TARGET (ES2022 - Modern runtime)
    // ============================================================================
    "target": "ES2022",
    "lib": ["ES2022"],
    "useDefineForClassFields": true,

    // ============================================================================
    // EMIT (Output configuration)
    // ============================================================================
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noEmit": true,

    // ============================================================================
    // INTEROP (Compatibility)
    // ============================================================================
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,

    // ============================================================================
    // SKIP CHECKS (Para libs externas - como Go's vendor)
    // ============================================================================
    "skipLibCheck": true,
    "skipDefaultLibCheck": true
  },

  // ============================================================================
  // INCLUDE/EXCLUDE
  // ============================================================================
  "include": [
    "f/**/*.ts",
    "internal/**/*.ts",
    "cmd/**/*.ts",
    "pkg/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/backup/*.ts",
    "**/v2.0_backup.ts",
    "**/v2.1_backup.ts"
  ],

  // ============================================================================
  // TYPENADO ADICIONAL (Go-like utilities)
  // ============================================================================
  "types": ["node"]
}
